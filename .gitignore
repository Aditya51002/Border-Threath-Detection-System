# .gitignore for Border Threat Detection System

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment Variables
.env
*.env

# Database
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# Models (large files)
models/*.pt
models/*.pth
models/*.onnx
!models/training/

# Uploads & Archives
uploads/
snapshots/
archives/
temp/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test files
test_*.db
test_*.py
*_test.py

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Distribution
*.tar.gz
*.zip

# Temporary files
*.tmp
*.bak
*.cache
